  "query": "\n                SELECT rf.id AS \"id!\", rf.hash AS \"hash!\"\n                FROM replay_files rf\n                JOIN games_users gu ON gu.replay_file_id = rf.id\n                WHERE gu.game_id = $1\n                ORDER BY (rf.header->>'frames')::int DESC NULLS LAST\n                LIMIT 1\n            ",
