{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["rally-point"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "utc",
  "title": "Rally-point health",
  "uid": "rally-point",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Relays by state per region",
      "description": "rp2_relays gauge, stacked: relay count per region split by lifecycle state (launching/live/draining).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (region,state) (rp2_relays)", "legendFormat": "{{region}} / {{state}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Relay launch / enroll / drain rate",
      "description": "rate(..._total[5m]) per region for relay launches issued, successful enrolls, and marked drains.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (region) (rate(rp2_relay_launches_total[5m]))", "legendFormat": "launch: {{region}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (region) (rate(rp2_relay_enrolls_total[5m]))", "legendFormat": "enroll: {{region}}" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (region) (rate(rp2_relay_drains_total[5m]))", "legendFormat": "drain: {{region}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Relay cold-start latency (p50/p90)",
      "description": "histogram_quantile over rp2_relay_cold_start_seconds buckets: time from launch to first enroll (ledger mode only).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.5, sum by (le) (rate(rp2_relay_cold_start_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.9, sum by (le) (rate(rp2_relay_cold_start_seconds_bucket[5m])))", "legendFormat": "p90" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Relay reaps & launch failures rate",
      "description": "rate(rp2_relay_reaped_total[5m]) by reap reason (launch_deadline/vanished/orphan) and rate(rp2_relay_launch_failures_total[5m]) by region.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (reason) (rate(rp2_relay_reaped_total[5m]))", "legendFormat": "reaped: {{reason}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (region) (rate(rp2_relay_launch_failures_total[5m]))", "legendFormat": "launch failure: {{region}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Active sessions by tenant + state",
      "description": "rp2_sessions_active gauge: sessions with a non-empty serving-relays set, split by loading/started state.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rp2_sessions_active", "legendFormat": "{{tenant}} / {{state}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Sessions created & holds rate",
      "description": "rate(rp2_sessions_created_total[5m]) (fresh mints) and rate(rp2_session_holds_total[5m]) (202 Provisioning holds) per tenant.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (tenant) (rate(rp2_sessions_created_total[5m]))", "legendFormat": "created: {{tenant}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (tenant) (rate(rp2_session_holds_total[5m]))", "legendFormat": "hold: {{tenant}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Desync increase (1h)",
      "description": "increase(rp2_desyncs_total[1h]) per tenant: desync notices handled in the trailing hour.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (tenant) (increase(rp2_desyncs_total[1h]))", "legendFormat": "{{tenant}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Warm targets per region",
      "description": "rp2_warm_target gauge: current provisioning demand per region (warm signals merged with coverage bootstrap), not a static pool size.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rp2_warm_target", "legendFormat": "{{region}}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Webhook notices pending",
      "description": "rp2_webhook_notices_pending gauge: per-tenant queued notice depth (NOTICE_QUEUE_CAPACITY minus remaining queue capacity).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rp2_webhook_notices_pending", "legendFormat": "{{tenant}}" }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Webhook notices dropped (total)",
      "description": "rp2_webhook_notices_dropped_total: process-lifetime count of notices dropped for capacity. Nonzero is an incident.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rp2_webhook_notices_dropped_total", "legendFormat": "dropped" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Webhook deliveries & attempt failures",
      "description": "rate(rp2_webhook_deliveries_total[5m]) by result (ok/gave_up) and rate(rp2_webhook_attempt_failures_total[5m]) by tenant (each failed delivery attempt).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (result) (rate(rp2_webhook_deliveries_total[5m]))", "legendFormat": "delivery: {{result}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (tenant) (rate(rp2_webhook_attempt_failures_total[5m]))", "legendFormat": "attempt failure: {{tenant}}" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Flight recordings by result & pinned",
      "description": "rate(rp2_flight_recordings_total[5m]) by result (stored/refused/lost) alongside increase(rp2_flight_recordings_pinned_total[5m]) (stores pinned under desync/).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (result) (rate(rp2_flight_recordings_total[5m]))", "legendFormat": "{{result}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(rp2_flight_recordings_pinned_total[5m])", "legendFormat": "pinned" }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Backbone RTT",
      "description": "rp2_backbone_rtt_ms per measured direction, from the coordinator's relay pair-RTT matrix.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rp2_backbone_rtt_ms", "legendFormat": "{{origin}} → {{target}}" }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Beacon backoff state",
      "description": "rp2_beacon_backoff per region: 1 while the coverage bootstrap is backing off a dead-beacon region, else 0.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rp2_beacon_backoff", "legendFormat": "{{region}}" }
      ]
    }
  ]
}
