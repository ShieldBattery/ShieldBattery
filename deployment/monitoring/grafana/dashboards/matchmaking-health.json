{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["matchmaking"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "utc",
  "title": "Matchmaking health",
  "uid": "matchmaking-health",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Queue size per mode",
      "description": "Live players queued per mode (server-rs view, sampled each search tick).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matchmaker_queue_size", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Population estimate (EWMA) per mode",
      "description": "Smoothed population driving the adaptive threshold. Absent for a mode until its first 60s window folds.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matchmaker_population_estimate", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Effective min quality per mode",
      "description": "Current adaptive quality threshold (seconds). Equal to the configured MIN_QUALITY when population is comfortable; lower (more negative) = more relaxed for low population.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matchmaker_effective_min_quality", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Matches formed (per second)",
      "description": "rate(matchmaker_matches_formed_total[5m]) per mode.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(matchmaker_matches_formed_total[5m])", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Match outcome: launched vs failed-by-phase",
      "description": "Node view. 'failed: accepting' is the ready-up funnel dropout (declines/timeouts/disconnects); 'drafting'/'loading' are later-stage failures.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(shieldbattery_matchmaker_match_launched_total[5m]))", "legendFormat": "launched" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (phase) (rate(shieldbattery_matchmaker_match_failed_total[5m]))", "legendFormat": "failed: {{phase}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Median formed-match quality per mode",
      "description": "matchmaker_match_quality p50 (seconds of wait). Summary metric.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matchmaker_match_quality{quantile=\"0.5\"}", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Median win-prob imbalance per mode",
      "description": "matchmaker_match_winprob_imbalance p50 = abs(0.5 - win probability). 0 is a perfectly balanced match.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 0.5, "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matchmaker_match_winprob_imbalance{quantile=\"0.5\"}", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Median formed-match latency per mode",
      "description": "matchmaker_match_latency_ms p50 = estimated worst-pair one-way latency.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matchmaker_match_latency_ms{quantile=\"0.5\"}", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Search tick duration",
      "description": "Wall-clock cost of one matchmaker search tick (p50/p99). Watch for growth as population scales — drives max_players_examined / search interval tuning.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matchmaker_search_tick_duration_seconds{quantile=\"0.5\"}", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "matchmaker_search_tick_duration_seconds{quantile=\"0.99\"}", "legendFormat": "p99" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Publish failures & requeues",
      "description": "rate(matchmaker_publish_failures_total[5m]) (Redis publish trouble — sustained non-zero precedes a restart) and rate(matchmaker_players_requeued_total[5m]) per mode (matches that failed to start).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(matchmaker_publish_failures_total[5m])", "legendFormat": "publish failures" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (mode) (rate(matchmaker_players_requeued_total[5m]))", "legendFormat": "requeue: {{mode}}" }
      ]
    }
  ]
}
