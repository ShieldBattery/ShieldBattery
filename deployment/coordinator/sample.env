# Copy to `.env` and fill in. Everything the coordinator itself reads is a
# COORDINATOR_* variable (one per CLI flag); the rest configures the sidecars.

# --- Image ---
# Tag of shieldbattery/rp2-coordinator to run — CI publishes one per
# rally-point2 main commit, tagged with the full commit SHA. Pin a SHA rather
# than `latest` so upgrades are deliberate: change this, `docker-compose pull
# coordinator`, `docker-compose up -d`.
RP2_VERSION=

# --- Core ---
# Listen inside the container; port 443 on the host maps here.
COORDINATOR_LISTEN=[::]:14910
# Shared secret relays present to open their control connection.
COORDINATOR_BOOTSTRAP_SECRET=
# Region registry (ids, display names, ping beacons, fallbacks).
COORDINATOR_REGIONS=/config/regions.json
# The relay-identity ledger. Lives on the coordinator_data volume; back it up by
# copying the file.
COORDINATOR_RELAY_LEDGER=/data/relay-ledger.sqlite

# --- TLS (terminated in-process; Let's Encrypt via ACME TLS-ALPN-01) ---
# The public hostname relays and app servers connect to; the certificate is
# issued for it automatically. DNS for it must point at this box before first
# start.
COORDINATOR_ACME_DOMAIN=
# ACME account contact (expiry/policy notices).
COORDINATOR_ACME_CONTACT=
# Account key + issued certificates persist here (on the coordinator_data
# volume), so restarts never re-issue.
COORDINATOR_ACME_CACHE=/data/acme
# Uncomment to issue from Let's Encrypt's STAGING directory while standing the
# box up — browser-untrusted certs, but no production rate-limit spend. Remove
# (and clear /data/acme) once the setup is proven.
#COORDINATOR_ACME_STAGING=true

# --- Relay provisioning (ECS/Fargate) ---
COORDINATOR_PROVISION_ECS_CONFIG=/config/ecs.json
# Credentials for the narrowly-scoped IAM user (RunTask/StopTask/DescribeTasks/
# ListTasks on the relay task family + ec2:DescribeNetworkInterfaces).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional tuning; the defaults are sensible.
#COORDINATOR_PROVISION_LAUNCH_DEADLINE_SECS=300
#COORDINATOR_RELAY_IDLE_SECS=600
#COORDINATOR_PROVISION_TICK_SECS=5
#COORDINATOR_WARM_TTL_SECS=600
#COORDINATOR_PROVISION_CREATE_HOLD_SECS=75

# --- Tenants ---
# The tenant registry: per-tenant state (active/suspended/revoked), inbound
# request-verification pubkeys (list two while rotating the app server's key),
# webhook URL, bounds. The file carries no secrets — each tenant names the env
# var (below) holding the coordinator's signing key for it.
COORDINATOR_TENANTS=/config/tenants.json
# Base64 (padded) PKCS#8 Ed25519 document — the coordinator's token/webhook
# signing key for the tenant, matching the "signing_key_env" in tenants.json.
COORDINATOR_TENANT_SB_SIGNING_KEY=

# --- Tokens ---
#COORDINATOR_PLAYER_TOKEN_LIFETIME_SECS=21600

# --- Tailscale (admin access; optional but recommended) ---
# A reusable, pre-authorized key from the tailnet admin console. With the state
# volume intact the node authenticates once and keeps its identity across
# restarts and recreates.
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=rp2-coordinator
#TAILSCALE_EXTRA_ARGS=
